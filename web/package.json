{
  "type": "module",
  "name": "gin-admin",
  "version": "3.0.0",
  "license": "MIT",
  "author": "silent-rain",
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "dev": "vite --mode serve-dev",
    "test": "vite --mode serve-test",
    "build:test": "vite build --mode serve-test",
    "build": "vite build --mode serve-prod",
    "preview:build": "npm run build && vite preview ",
    "preview": "vite preview --mode serve-dev",
    "lint": "eslint src --fix",
    "prepare": "#husky install",
    "test:unit": "vue-cli-service test:unit",
    "test:watchAll": "vue-cli-service test:unit --watchAll",
    "test:cov": "vue-cli-service test:unit --coverage",
    "test:majestic": "majestic",
    "vitest": "vitest --ui",
    "tsc-check": "tsc",
    "coverage": "vitest run --coverage",
    "format": "prettier --write \"{src,mock}/**/*.{vue,ts,tsx,js,jsx,css,scss,json,md}\" ./*.json ./*.md",
    "deps:update": "pnpm update --latest",
    "deps:update:interactive": "pnpm update --latest --interactive",
    "deps:check": "pnpm outdated"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "@highlightjs/vue-plugin": "^2.1.0",
    "axios": "^1.6.7",
    "d3": "7.9.0",
    "driver.js": "^1.4.0",
    "echarts": "^6.1.0",
    "element-plus": "^2.5.3",
    "highlight.js": "^11.9.0",
    "js-error-collection": "^1.0.8",
    "js-md5": "^0.8.3",
    "mitt": "3.0.1",
    "moment-mini": "2.29.4",
    "nprogress": "0.2.0",
    "path-browserify": "^1.0.1",
    "path-to-regexp": "^8.4.2",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "4.7.1",
    "screenfull": "^6.0.2",
    "sortablejs": "1.15.7",
    "splitpanes": "^4.1.2",
    "tinymce": "^8.6.0",
    "vue": "^3.4.15",
    "vue-clipboard3": "^2.0.0",
    "vue-i18n": "^11.4.5",
    "vue-router": "^5.1.0",
    "vxe-table": "^4.5.18",
    "xe-utils": "^4.0.9",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@babel/eslint-parser": "7.29.7",
    "@tinymce/tinymce-vue": "^6.3.0",
    "@types/mockjs": "^1.0.10",
    "@types/node": "^25.9.3",
    "@types/nprogress": "^0.2.3",
    "@types/path-browserify": "^1.0.2",
    "@vitejs/plugin-legacy": "^8.0.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vitest/coverage-c8": "^0.33.0",
    "@vitest/ui": "^4.1.9",
    "@vue/cli-plugin-unit-jest": "^5.0.8",
    "@vue/cli-service": "^5.0.8",
    "@vue/compiler-sfc": "^3.5.38",
    "@vue/test-utils": "^2.4.4",
    "ejs": "^6.0.1",
    "eslint": "^10.5.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "jsonc-eslint-parser": "^3.1.0",
    "majestic": "1.8.1",
    "mockjs": "1.1.0",
    "prettier": "^3.8.4",
    "resize-observer-polyfill": "^1.5.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass": "^1.70.0",
    "svg-sprite-loader": "6.0.11",
    "typescript": "^6.0.3",
    "unocss": "^66.7.2",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "unplugin-vue-define-options": "^3.1.2",
    "vite": "^8.0.16",
    "vite-plugin-eslint": "^1.8.1",
    "vite-plugin-mkcert": "^2.1.0",
    "vite-plugin-mock": "^3.0.2",
    "vite-plugin-svg-icons": "^2.0.1",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "vite-plugin-mock",
        "unplugin-auto-import",
        "unplugin-vue-components",
        "unocss",
        "unplugin",
        "vite-plugin-mock",
        "@vitejs/plugin-legacy",
        "@vitejs/plugin-vue",
        "@vitejs/*",
        "@babel/*",
        "vite",
        "vue",
        "@unocss/vite",
        "rollup",
        "vue-jest"
      ]
    }
  },
  "browserslist": [
    "> 1%",
    "not ie 11",
    "not op_mini all"
  ],
  "engines": {
    "node": ">= 18 <=26",
    "pnpm": ">= 10"
  }
}